---
import Logo from './Logo.astro';
import i18n from '../data/i18n.json';
import config from '../data/config.json';
const t = (key: string) => (i18n as Record<string, { es: string; en: string }>)[key]?.es ?? key;
const waLink = `https://wa.me/${config.whatsapp.number}?text=${encodeURIComponent(config.whatsapp.message.es)}`;
---
<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <span class="footer-mark"><Logo gradientId="wgfoot" size={26} /></span>
      <div class="footer-name-wrap">
        <span class="footer-name">Oscar López</span>
        <span class="footer-role" data-i18n="footer.role">{t('footer.role')}</span>
      </div>
    </div>
    <div class="footer-social">
      <a href={waLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="social-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.4A10 10 0 1 0 12 2Zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-3.1.8.8-3-.2-.3A8 8 0 1 1 12 20Z"/></svg>
      </a>
      <a href="#" data-email-link aria-label="Email" class="social-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      </a>
      <a href="https://github.com/LuceOsc" target="_blank" rel="noopener" aria-label="GitHub" class="social-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.86c-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.1-1.49-1.1-1.49-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.34-1.11.62-1.36-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.72 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.64 1.03 2.76 0 3.93-2.34 4.79-4.57 5.05.36.32.67.94.67 1.9v2.82c0 .27.18.6.69.49C19.13 20.6 22 16.77 22 12.25 22 6.58 17.52 2 12 2Z"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/oscar-jos%C3%A9-l%C3%B3pez-lucero/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05C20.4 8.65 21 11 21 14.1V21h-4v-6.1c0-1.45-.03-3.3-2-3.3s-2.3 1.57-2.3 3.2V21H9V9Z"/></svg>
      </a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span class="footer-made" data-i18n="footer.made">{t('footer.made')}</span>
      <span class="footer-copy">© 2026 Oscar López</span>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); background: var(--bg2); }
  .footer-top {
    max-width: 1240px;
    margin: 0 auto;
    padding: 34px 24px;
    display: flex;
    gap: 18px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .footer-brand { display: flex; align-items: center; gap: 11px; }
  .footer-mark { display: flex; }
  .footer-name-wrap { display: flex; flex-direction: column; line-height: 1.2; }
  .footer-name { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 15px; }
  .footer-role { font-size: 12px; color: var(--muted); }

  .footer-social { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
  .social-icon { color: var(--muted); transition: color .2s; display: flex; }
  .social-icon:hover { color: var(--text); }

  .footer-bottom { border-top: 1px solid var(--border); }
  .footer-bottom-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .footer-made { font-size: 12.5px; color: var(--muted); }
  .footer-copy { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--muted); }
</style>
