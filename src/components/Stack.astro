  { name: 'MySQL', color: '#60a5fa', bg: 'rgba(96,165,250,.14)', glow: 'rgba(96,165,250,.3)', icon: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>', strokeWidth: '1.6' },
  { name: 'MariaDB', color: '#22d3ee', bg: 'rgba(34,211,238,.14)', glow: 'rgba(34,211,238,.3)', icon: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v12c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M9 11l2 2 3-4"/>', strokeWidth: '1.6' },
];
const design = [
  { name: 'Figma', color: '#f472b6', bg: 'rgba(244,114,182,.14)', glow: 'rgba(244,114,182,.3)', icon: '<circle cx="9" cy="5.5" r="2.5"/><circle cx="9" cy="12" r="2.5"/><circle cx="9" cy="18.5" r="2.5"/><circle cx="15" cy="5.5" r="2.5"/><circle cx="15" cy="12" r="2.5"/>', strokeWidth: '1.5' },
  { name: 'Adobe XD', color: '#a78bfa', bg: 'rgba(167,139,250,.16)', glow: 'rgba(167,139,250,.3)', label: 'Xd' },
  { name: 'Photoshop', color: '#38bdf8', bg: 'rgba(56,189,248,.16)', glow: 'rgba(56,189,248,.3)', label: 'Ps' },
  { name: 'CorelDRAW', color: '#34d399', bg: 'rgba(52,211,153,.16)', glow: 'rgba(52,211,153,.3)', icon: '<polygon points="12 3 20 8 17 19 7 19 4 8"/><path d="M9 12l2 2 4-4"/>', strokeWidth: '1.5' },
];
const tools = [
  { name: 'Git', color: '#fb923c', bg: 'rgba(251,146,60,.15)', glow: 'rgba(251,146,60,.3)', icon: '<circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="9" r="2.5"/><path d="M6 8.5v7M8.4 7.5 15.6 9M18 11.5c0 4-6 1.5-6 4.5"/>', strokeWidth: '1.7' },
  { name: 'Workflow', i18nKey: 'stack.workflow', color: '#60a5fa', bg: 'rgba(96,165,250,.14)', glow: 'rgba(96,165,250,.3)', icon: '<rect x="3" y="4" width="6" height="6" rx="1.5"/><rect x="15" y="4" width="6" height="6" rx="1.5"/><rect x="9" y="14" width="6" height="6" rx="1.5"/><path d="M6 10v2h12v-2M12 12v2"/>', strokeWidth: '1.6' },
];
const ai = [
  { name: 'ChatGPT', color: '#34d399', bg: 'rgba(52,211,153,.16)', glowHover: 'rgba(52,211,153,.7)', icon: '<path d="M12 3.5a3 3 0 0 1 2.9 2.2 3 3 0 0 1 1.6 5.2 3 3 0 0 1-1.6 5.2A3 3 0 0 1 12 20.5a3 3 0 0 1-2.9-2.2 3 3 0 0 1-1.6-5.2 3 3 0 0 1 1.6-5.2A3 3 0 0 1 12 3.5Z"/>', strokeWidth: '1.4' },
  { name: 'Claude', color: '#d97757', bg: 'rgba(217,119,87,.18)', glowHover: 'rgba(217,119,87,.7)', fill: true, icon: '<path d="M12 2.5 14 9l6.5-2L16 12l4.5 5L14 15l-2 6.5L10 15l-6.5 2L8 12 3.5 7 10 9Z"/>' },
  { name: 'GitHub Copilot', color: '#60a5fa', bg: 'rgba(96,165,250,.16)', glowHover: 'rgba(96,165,250,.7)', icon: '<path d="M5 11c0-2 1.5-3.5 3.5-3.5h7C17.5 7.5 19 9 19 11v1.5c0 2.5-2 4.5-4.5 4.5h-5C7 17 5 15 5 12.5Z"/><circle cx="9.5" cy="12" r="1"/><circle cx="14.5" cy="12" r="1"/><path d="M9 7.5 8 5M15 7.5 16 5"/>', strokeWidth: '1.5' },
  { name: 'Base44', color: '#22d3ee', bg: 'rgba(34,211,238,.16)', glowHover: 'rgba(34,211,238,.7)', icon: '<path d="M12 3 20 7.5v9L12 21 4 16.5v-9Z"/><path d="m4 7.5 8 4.5 8-4.5M12 12v9"/>', strokeWidth: '1.5' },
];

const categories = [
  { key: 'stack.cat1', descKey: 'stack.cat1d', gradient: 'linear-gradient(135deg,#8b5cf6,#6366f1)', glow: 'rgba(124,58,237,.3)', border: 'rgba(139,92,246,.45)', boxGlow: 'rgba(124,58,237,.16)', icon: '<polyline points="9 8 5 12 9 16"/><polyline points="15 8 19 12 15 16"/>', items: frontend },
  { key: 'stack.cat2', descKey: 'stack.cat2d', gradient: 'linear-gradient(135deg,#3b82f6,#1d4ed8)', glow: 'rgba(37,99,235,.3)', border: 'rgba(59,130,246,.45)', boxGlow: 'rgba(37,99,235,.16)', icon: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>', items: backend },
  { key: 'stack.cat3', descKey: 'stack.cat3d', gradient: 'linear-gradient(135deg,#22d3ee,#3b82f6)', glow: 'rgba(34,211,238,.3)', border: 'rgba(34,211,238,.45)', boxGlow: 'rgba(34,211,238,.16)', icon: '<polygon points="12 3 21 8 12 13 3 8"/><polyline points="3 13 12 18 21 13"/>', items: design },
  { key: 'stack.cat4', descKey: 'stack.cat4d', gradient: 'linear-gradient(135deg,#6366f1,#8b5cf6)', glow: 'rgba(99,102,241,.3)', border: 'rgba(99,102,241,.45)', boxGlow: 'rgba(99,102,241,.16)', icon: '<circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="9" r="2.5"/><path d="M6 8.5v7M8.4 7.5 15.6 9M18 11.5c0 4-6 1.5-6 4.5"/>', items: tools },
];
---
<section id="stack" class="stack">
  <div data-reveal class="section-head">
    <div class="eyebrow" style="color:#22d3ee;">
      <span class="dot" style="background:#22d3ee; box-shadow:0 0 10px #22d3ee;"></span>
      <span data-i18n="stack.label">{t('stack.label')}</span>
    </div>
    <h2 class="section-title" data-i18n="stack.title">{t('stack.title')}</h2>
    <p class="section-sub" data-i18n="stack.sub">{t('stack.sub')}</p>
  </div>

  <div class="stack-grid">
    {categories.map((c) => (
      <div data-reveal class="stack-card" style={`--st-border:${c.border}; --st-glow:${c.boxGlow};`}>
        <div class="stack-head">
          <span class="stack-icon" style={`background:${c.gradient};`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
          </span>
          <div>
            <h3 class="stack-title" data-i18n={c.key}>{t(c.key)}</h3>
            <p class="stack-desc" data-i18n={c.descKey}>{t(c.descKey)}</p>
          </div>
        </div>
        <div class="tech-pills">
          {c.items.map((it) => (
            <span class="tech-pill" style={`--pill-border:${it.glow ?? it.glowHover}; --pill-glow:${it.glow ?? it.glowHover};`}>
              <span class="tech-icon" style={`background:${it.bg};`}>
                {it.label ? (
                  <span class="tech-letter" style={`color:${it.color};`}>{it.label}</span>
                ) : (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill={it.fill ? it.color : 'none'} stroke={it.fill ? 'none' : it.color} stroke-width={it.strokeWidth} stroke-linecap="round" stroke-linejoin="round" set:html={it.icon} />
                )}
              </span>
              <span data-i18n={it.i18nKey}>{it.i18nKey ? t(it.i18nKey) : it.name}</span>
            </span>
          ))}
        </div>
      </div>
    ))}

    <div data-reveal class="ai-card">
      <div class="ai-inner">
        <div class="ai-grid" aria-hidden="true"></div>
        <div class="ai-glow" aria-hidden="true"></div>
        <div class="ai-head">
          <span class="ai-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/><circle cx="12" cy="12" r="3.4"/></svg>
          </span>
          <div class="ai-copy">
            <div class="ai-tag">
              <span class="glow-dot" style="background:#a78bfa; box-shadow:0 0 8px #a78bfa;"></span>
              <span data-i18n="stack.ai_tag">{t('stack.ai_tag')}</span>
            </div>
            <h3 class="ai-title" data-i18n="stack.cat5">{t('stack.cat5')}</h3>
            <p class="ai-desc" data-i18n="stack.cat5d">{t('stack.cat5d')}</p>
          </div>
        </div>
        <div class="ai-pills">
          {ai.map((it) => (
            <span class="ai-pill" style={`--pill-glow:${it.glowHover};`}>
              <span class="tech-icon" style={`background:${it.bg};`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill={it.fill ? it.color : 'none'} stroke={it.fill ? 'none' : it.color} stroke-width={it.strokeWidth} stroke-linecap="round" stroke-linejoin="round" set:html={it.icon} />
              </span>
              <span>{it.name}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stack { max-width: 1240px; margin: 0 auto; padding: clamp(70px, 11vw, 130px) 24px; }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 18px;
    margin-top: 46px;
  }
  .stack-card {
    position: relative;
    padding: 24px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--card);
    transition: transform .3s, border-color .3s, box-shadow .3s;
  }
  .stack-card:hover { transform: translateY(-5px); border-color: var(--st-border); box-shadow: 0 22px 54px var(--st-glow); }
  .stack-head { display: flex; align-items: center; gap: 13px; }
  .stack-icon {
    display: flex; width: 44px; height: 44px;
    align-items: center; justify-content: center;
    border-radius: 12px;
    box-shadow: 0 8px 22px rgba(124,58,237,.3);
    flex: none;
  }
  .stack-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 17px; margin: 0; }
  .stack-desc { font-size: 12.5px; color: var(--muted); margin: 3px 0 0; line-height: 1.4; }

  .tech-pills { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 18px; }
  .tech-pill {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 13px 8px 8px;
    border-radius: 11px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-size: 13.5px;
    font-weight: 500;
    transition: border-color .25s, box-shadow .25s, transform .25s;
  }
  .tech-pill:hover { border-color: var(--pill-border); box-shadow: 0 0 18px var(--pill-glow); transform: translateY(-2px); }
  .tech-icon {
    display: flex; width: 28px; height: 28px;
    align-items: center; justify-content: center;
    border-radius: 8px;
    flex: none;
  }
  .tech-letter { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; }

  .ai-card {
    position: relative;
    grid-column: 1 / -1;
    padding: 1.5px;
    border-radius: 20px;
    background: linear-gradient(120deg, rgba(139,92,246,.8), rgba(59,130,246,.35) 50%, rgba(34,211,238,.7));
    box-shadow: 0 22px 60px rgba(124,58,237,.22);
    overflow: hidden;
  }
  .ai-inner {
    position: relative;
    padding: 26px clamp(22px, 3vw, 32px);
    border-radius: 18px;
    background: linear-gradient(150deg, #11101d, #0c0c16);
    overflow: hidden;
  }
  .ai-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(167,139,250,.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(167,139,250,.06) 1px, transparent 1px);
    background-size: 32px 32px;
    -webkit-mask-image: radial-gradient(circle at 85% 10%, #000, transparent 70%);
    mask-image: radial-gradient(circle at 85% 10%, #000, transparent 70%);
  }
  .ai-glow {
    position: absolute; top: -40%; right: -6%;
    width: 36%; height: 170%;
    background: radial-gradient(circle, rgba(139,92,246,.3), transparent 65%);
    filter: blur(26px);
    pointer-events: none;
  }
  .ai-head { position: relative; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .ai-icon {
    display: flex; width: 48px; height: 48px;
    align-items: center; justify-content: center;
    border-radius: 13px;
    background: linear-gradient(135deg,#8b5cf6,#22d3ee);
    box-shadow: 0 10px 26px rgba(124,58,237,.4);
    flex: none;
  }
  .ai-copy { flex: 1 1 auto; min-width: 200px; }
  .ai-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 4px 11px;
    border-radius: 100px;
    border: 1px solid rgba(167,139,250,.4);
    background: rgba(139,92,246,.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: .14em;
    color: #c4b5fd;
    text-transform: uppercase;
  }
  .ai-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 18px; margin: 9px 0 0; }
  .ai-desc { font-size: 13px; color: #b9b9d4; margin: 4px 0 0; line-height: 1.45; }
  .ai-pills { position: relative; display: flex; flex-wrap: wrap; gap: 9px; margin-top: 20px; }
  .ai-pill {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 9px 14px 9px 9px;
    border-radius: 11px;
    border: 1px solid rgba(167,139,250,.28);
    background: rgba(255,255,255,.04);
    font-size: 13.5px;
    font-weight: 500;
    color: #ECECF4;
    transition: border-color .25s, box-shadow .25s, transform .25s;
  }
  .ai-pill:hover { border-color: var(--pill-glow); box-shadow: 0 0 20px var(--pill-glow); transform: translateY(-2px); }
</style>
