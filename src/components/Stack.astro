  { name: 'React', color: '#22d3ee', bg: 'rgba(34,211,238,.14)', glow: 'rgba(34,211,238,.3)', icon: '<circle cx="12" cy="12" r="1.8"/><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>', strokeWidth: '1.4' },
  { name: 'Astro', color: '#c084fc', bg: 'rgba(192,132,252,.14)', glow: 'rgba(192,132,252,.3)', icon: '<path d="M12 2 17 19 12 16 7 19Z"/><path d="M10 20a3 3 0 0 0 4 0"/>', strokeWidth: '1.6' },
];
