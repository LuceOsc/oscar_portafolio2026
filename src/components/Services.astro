---
import i18n from '../data/i18n.json';
import config from '../data/config.json';
const t = (key: string) => (i18n as Record<string, { es: string; en: string }>)[key]?.es ?? key;
const waLink = `https://wa.me/${config.whatsapp.number}?text=${encodeURIComponent(config.whatsapp.message.es)}`;

const services = [
  {
    // Only this card gets its own WhatsApp button, since custom systems are the flagship offer
    titleKey: 'serv.1t', descKey: 'serv.1d', exampleKey: 'serv.1ex', gradient: 'linear-gradient(135deg,#8b5cf6,#3b82f6)', glow: 'rgba(124,58,237,.18)', border: 'rgba(139,92,246,.5)',
    icon: '<polyline points="9 8 5 12 9 16"/><polyline points="15 8 19 12 15 16"/>', wa: true,
  },
  {
    titleKey: 'serv.2t', descKey: 'serv.2d', exampleKey: 'serv.2ex', gradient: 'linear-gradient(135deg,#22d3ee,#3b82f6)', glow: 'rgba(34,211,238,.16)', border: 'rgba(34,211,238,.5)',
    icon: '<rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>',
  },
  {
    titleKey: 'serv.3t', descKey: 'serv.3d', exampleKey: 'serv.3ex', gradient: 'linear-gradient(135deg,#34d399,#22d3ee)', glow: 'rgba(52,211,153,.16)', border: 'rgba(52,211,153,.5)',
    icon: '<path d="M21 12a9 9 0 1 1-2.6-6.4"/><path d="M21 4v5h-5"/>',
  },
  {
    titleKey: 'serv.4t', descKey: 'serv.4d', exampleKey: 'serv.4ex', gradient: 'linear-gradient(135deg,#6366f1,#3b82f6)', glow: 'rgba(37,99,235,.18)', border: 'rgba(59,130,246,.5)',
    icon: '<path d="M9 17H7a5 5 0 0 1 0-10h2"/><path d="M15 7h2a5 5 0 1 1 0 10h-2"/><line x1="8" y1="12" x2="16" y2="12"/>',
  },
];
---
<section id="services" class="services">
  <div data-reveal class="section-head">
    <div class="eyebrow">
      <span class="dot" style="background:#8b5cf6; box-shadow:0 0 10px #8b5cf6;"></span>
      <span data-i18n="serv.label">{t('serv.label')}</span>
    </div>
    <h2 class="section-title" data-i18n="serv.title">{t('serv.title')}</h2>
    <p class="section-sub" data-i18n="serv.sub">{t('serv.sub')}</p>
  </div>

  <div class="services-grid">
    {services.map((s) => (
      <div data-reveal class="service-card" style={`--sv-border:${s.border}; --sv-glow:${s.glow};`}>
        <div class="service-icon" style={`background:${s.gradient};`}>
          <svg width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
        </div>
        <h3 class="service-title" data-i18n={s.titleKey}>{t(s.titleKey)}</h3>
        <p class="service-desc" data-i18n={s.descKey}>{t(s.descKey)}</p>
        <p class="service-example" data-i18n={s.exampleKey}>{t(s.exampleKey)}</p>
        {s.wa && (
          <a href={waLink} target="_blank" rel="noopener" class="service-wa-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.4A10 10 0 1 0 12 2Zm5.6 14.1c-.2.6-1.4 1.2-1.9 1.2-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5-4.5-.2-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.4.7-.4h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.2.1.4.1.6-.1l.8-1c.2-.2.4-.2.6-.1l2 .9c.2.1.4.2.4.3.1.1.1.6-.1 1.2Z"/></svg>
            <span data-i18n="serv.waBtn">{t('serv.waBtn')}</span>
          </a>
        )}
      </div>
    ))}

  </div>

  <div data-reveal class="service-cta">
    <div class="service-cta-text">
      <div class="service-icon service-icon-outline">
        <svg width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.4A10 10 0 1 0 12 2Z"/></svg>
      </div>
      <h3 class="service-title" data-i18n="contact.title">{t('contact.title')}</h3>
    </div>
    <a href="#contact" class="service-link">
      <span data-i18n="serv.ctaLink">{t('serv.ctaLink')}</span>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</section>

<style>
  .services { max-width: 1240px; margin: 0 auto; padding: clamp(70px, 11vw, 130px) 24px; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 18px;
    margin-top: 46px;
  }
  .service-card {
    position: relative;
    padding: 26px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--card);
    overflow: hidden;
    transition: transform .3s, border-color .3s, box-shadow .3s;
  }
  .service-card:hover {
    transform: translateY(-6px);
    border-color: var(--sv-border);
    box-shadow: 0 20px 52px var(--sv-glow);
  }
  .service-icon {
    display: flex;
    width: 48px; height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 13px;
    box-shadow: 0 10px 24px rgba(124,58,237,.32);
  }
  .service-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 18px;
    margin: 18px 0 0;
  }
  .service-desc { font-size: 14px; line-height: 1.55; color: var(--muted); margin: 9px 0 0; }
  .service-example {
    font-size: 12.5px;
    line-height: 1.5;
    color: #a78bfa;
    margin: 12px 0 0;
    padding-top: 12px;
    border-top: 1px dashed var(--border);
  }
  .service-wa-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 14px;
    padding: 9px 14px;
    border-radius: 10px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
  }

  .service-cta {
    margin-top: 18px;
    padding: 22px 28px;
    border-radius: 18px;
    border: 1px dashed var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }
  .service-cta-text { display: flex; align-items: center; gap: 16px; }
  .service-icon-outline {
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: none;
    flex: none;
  }
  .service-cta .service-title { margin: 0; }
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #a78bfa;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    flex: none;
  }

  @media (max-width: 560px) {
    .service-cta { flex-direction: column; align-items: flex-start; }
  }
</style>
