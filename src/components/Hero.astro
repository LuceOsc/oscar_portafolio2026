---
import i18n from '../data/i18n.json';
import config from '../data/config.json';
const t = (key: string) => (i18n as Record<string, { es: string; en: string }>)[key]?.es ?? key;
const waLink = `https://wa.me/${config.whatsapp.number}?text=${encodeURIComponent(config.whatsapp.message.es)}`;
---
<header class="hero">
  <div class="hero-copy">
    <div class="badge">
      <span class="glow-dot"></span>
      <span data-i18n="hero.badge">{t('hero.badge')}</span>
    </div>

    <h1 class="hero-title">
      Oscar
      <span class="gradient-text">López</span>
    </h1>

    <p class="hero-role" data-i18n="hero.role">{t('hero.role')}</p>
    <p class="hero-phrase" data-i18n="hero.phrase">{t('hero.phrase')}</p>

    <div class="hero-actions">
      <a href={waLink} target="_blank" rel="noopener" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.4A10 10 0 1 0 12 2Zm5.6 14.1c-.2.6-1.4 1.2-1.9 1.2-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5-4.5-.2-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.4.7-.4h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.2.1.4.1.6-.1l.8-1c.2-.2.4-.2.6-.1l2 .9c.2.1.4.2.4.3.1.1.1.6-.1 1.2Z"/></svg>
        <span data-i18n="hero.btn1">{t('hero.btn1')}</span>
      </a>
      <a href="#projects" class="btn btn-secondary">
        <span data-i18n="hero.btn2">{t('hero.btn2')}</span>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">8+</span>
        <span class="stat-label" data-i18n="hero.s1">{t('hero.s1')}</span>
      </div>
      <span class="stat-sep"></span>
      <div class="stat">
        <span class="stat-num">5+</span>
        <span class="stat-label" data-i18n="hero.s2">{t('hero.s2')}</span>
      </div>
      <span class="stat-sep"></span>
      <div class="stat">
        <span class="stat-num">100%</span>
        <span class="stat-label" data-i18n="hero.s3">{t('hero.s3')}</span>
      </div>
    </div>
  </div>

  <div class="hero-art">
    <div class="art-glow" aria-hidden="true"></div>
    <div class="art-mark" aria-hidden="true">
      <svg viewBox="0 0 64 64" fill="none" stroke="#a78bfa" stroke-width="1" stroke-linejoin="round" stroke-linecap="round">
        <path d="M16 8 L27 24 L11 25 Z"/><path d="M48 8 L37 24 L53 25 Z"/>
        <path d="M11 25 L24 23 L32 26 L40 23 L53 25 L50 42 L40 52 L32 55 L24 52 L14 42 Z"/>
        <path d="M22 33 L28 35"/><path d="M42 33 L36 35"/><path d="M30 41 L32 43 L34 41"/>
        <path d="M21 41 L9 39 M21 44 L10 47"/><path d="M43 41 L55 39 M43 44 L54 47"/>
      </svg>
    </div>

    <div class="photo-frame">
      <div class="photo-inner">
        <div class="photo-grid" aria-hidden="true"></div>
        <img src={`${import.meta.env.BASE_URL}assets/oscar-cutout.png`} alt="Oscar López" class="photo-img" />
        <div class="photo-shade" aria-hidden="true"></div>
        <span class="hud hud-tl"></span>
        <span class="hud hud-tr"></span>
        <span class="hud hud-bl"></span>
        <span class="hud hud-br"></span>

        <div class="chip chip-avail">
          <span class="glow-dot"></span>
          <span data-i18n="hero.chip1">{t('hero.chip1')}</span>
        </div>
      </div>
    </div>

    <div class="chip chip-stack">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 8 5 12 9 16"/><polyline points="15 8 19 12 15 16"/></svg>
      <span data-i18n="hero.chip2">{t('hero.chip2')}</span>
    </div>
  </div>
</header>

<style>
  .hero {
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) 24px clamp(56px, 9vw, 110px);
    display: flex;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-copy { flex: 1 1 440px; min-width: 300px; }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 15px;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: var(--surface);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: .12em;
    color: #a78bfa;
    text-transform: uppercase;
  }
  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(46px, 8vw, 86px);
    line-height: .98;
    letter-spacing: -.03em;
    margin: 22px 0 0;
  }
  .hero-title .gradient-text { display: block; }
  .hero-role {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: clamp(17px, 2.4vw, 22px);
    color: var(--text);
    margin: 16px 0 0;
    letter-spacing: -.01em;
  }
  .hero-phrase {
    font-size: clamp(15px, 1.7vw, 18px);
    line-height: 1.6;
    color: var(--muted);
    margin: 18px 0 0;
    max-width: 480px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px; }
  .hero-stats { display: flex; gap: 28px; flex-wrap: wrap; margin-top: 42px; }
  .stat { display: flex; flex-direction: column; }
  .stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 28px;
    background: linear-gradient(120deg, #a78bfa, #60a5fa);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .stat-label { font-size: 12.5px; color: var(--muted); margin-top: 2px; }
  .stat-sep { width: 1px; background: var(--border); }

  .hero-art {
    flex: 1 1 360px;
    min-width: 290px;
    display: flex;
    justify-content: center;
    position: relative;
  }
  .art-glow {
    position: absolute;
    width: 90%; height: 90%; top: 5%;
    background: radial-gradient(circle at 55% 40%, rgba(139,92,246,.4), transparent 62%);
    filter: blur(42px);
  }
  .art-mark {
    position: absolute;
    width: 118%; height: 118%; top: -9%;
    opacity: .10;
  }
  .art-mark svg { width: 100%; height: 100%; }

  .photo-frame {
    position: relative;
    width: min(420px, 82vw);
    border-radius: 26px;
    padding: 1.5px;
    background: linear-gradient(160deg, rgba(139,92,246,.85), rgba(59,130,246,.25) 50%, rgba(34,211,238,.7));
    box-shadow: 0 34px 90px rgba(124,58,237,.4);
    animation: float 8s ease-in-out infinite;
  }
  .photo-inner {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: radial-gradient(120% 90% at 50% 8%, rgba(139,92,246,.32), rgba(59,130,246,.12) 45%, var(--bg2) 78%);
  }
  .photo-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
    background-size: 30px 30px;
    -webkit-mask-image: radial-gradient(circle at 50% 30%, #000, transparent 75%);
    mask-image: radial-gradient(circle at 50% 30%, #000, transparent 75%);
  }
  .photo-img {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 4.6;
    object-fit: cover;
    object-position: center top;
    filter: drop-shadow(0 18px 40px rgba(124,58,237,.4));
  }
  .photo-shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,8,13,.45), transparent 42%);
    pointer-events: none;
  }
  .hud { position: absolute; width: 18px; height: 18px; }
  .hud-tl { top: 13px; left: 13px; border-top: 2px solid rgba(167,139,250,.9); border-left: 2px solid rgba(167,139,250,.9); border-top-left-radius: 6px; }
  .hud-tr { top: 13px; right: 13px; border-top: 2px solid rgba(96,165,250,.9); border-right: 2px solid rgba(96,165,250,.9); border-top-right-radius: 6px; }
  .hud-bl { bottom: 13px; left: 13px; border-bottom: 2px solid rgba(96,165,250,.9); border-left: 2px solid rgba(96,165,250,.9); border-bottom-left-radius: 6px; }
  .hud-br { bottom: 13px; right: 13px; border-bottom: 2px solid rgba(34,211,238,.9); border-right: 2px solid rgba(34,211,238,.9); border-bottom-right-radius: 6px; }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 100px;
    backdrop-filter: blur(8px);
  }
  .chip-avail {
    position: absolute;
    left: 16px; bottom: 16px;
    padding: 7px 13px;
    background: rgba(10,10,18,.55);
    border: 1px solid rgba(255,255,255,.14);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #e8e8f4;
    letter-spacing: .04em;
  }
  .chip-stack {
    position: absolute;
    top: 8%; right: 2%;
    padding: 9px 14px;
    border-radius: 13px;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(0,0,0,.3);
    font-size: 12.5px;
    font-weight: 600;
    animation: float 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-frame, .chip-stack { animation: none; }
  }

  @media (max-width: 760px) {
    .hero { flex-direction: column; text-align: center; }
    .hero-copy { display: flex; flex-direction: column; align-items: center; }
    .hero-phrase { max-width: 100%; }
    .hero-actions, .hero-stats { justify-content: center; }
    .hero-stats { gap: 18px 26px; }
    .hero-art { order: -1; width: fit-content; max-width: 100%; margin: 0 auto 8px; }
    .art-mark { opacity: .07; }
    .chip-stack { top: 6%; right: -4%; }
  }

  @media (max-width: 420px) {
    .hero { gap: 40px; }
    .hero-stats { flex-direction: column; gap: 14px; }
    .stat-sep { display: none; }
    .hero-actions { flex-direction: column; width: 100%; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
